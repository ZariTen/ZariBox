#!/usr/bin/env bash
# ZariBox - Declarative Distrobox manager with Nix-like feel
# Usage: zaribox <command> [file.yaml]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
for module in \
    "${SCRIPT_DIR}/zaribox.d/core.sh" \
    "${SCRIPT_DIR}/zaribox.d/yaml.sh" \
    "${SCRIPT_DIR}/zaribox.d/config.sh" \
    "${SCRIPT_DIR}/zaribox.d/backend_distrobox.sh" \
    "${SCRIPT_DIR}/zaribox.d/backend.sh" \
    "${SCRIPT_DIR}/zaribox.d/state.sh" \
    "${SCRIPT_DIR}/zaribox.d/pkgmgr.sh" \
    "${SCRIPT_DIR}/zaribox.d/commands.sh"
do
    if [[ ! -f "$module" ]]; then
        printf '%s\n' "Missing module: $module" >&2
        exit 1
    fi
    source "$module"
done

main "$@"
